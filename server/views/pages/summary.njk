{% extends "../partials/layout.njk" %}

{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{%- from "moj/components/alert/macro.njk" import mojAlert -%}

{% block content %}

{% if suspendedList | length > 0 %}
    {% set suspendedProductsBulletList %}
    <ul class="govuk-list govuk-list--bullet" id="suspended-services-alert-list">
      {% for item in suspendedList %}
        <li>{{ item.label }}</li>
      {% endfor %}
    </ul>
    {% endset %}

    {% if suspendedList | length > 1 %}
        {% set warningTitle = "Suspended Products Selected" %}
        {% set warningDesc = '<p>The following selected products are currently Suspended</p>' ~ suspendedProductsBulletList ~ '<p>You can still submit your request however the report will <b>NOT</b> complete until all selected products have been unsuspended.</p>' %}
    {% else %}
        {% set warningTitle = "Suspended product selected" %}
        {% set warningDesc = '<p>The following selected products are currently Suspended</p>' ~ suspendedProductsBulletList ~ '<p>You can still submit your request however the report will <b>NOT</b> complete until the product is unsuspended.</p>' %}
    {% endif %}

    {{ mojAlert({
        variant: "warning",
        title: warningTitle,
        showTitleAsHeading: true,
        dismissible: false,
        html: warningDesc
    }) }}
{% endif %}

  <form action="/summary" method="post">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    <legend class="govuk-fieldset__legend govuk-fieldset__legend--l">
        <h1 class="govuk-fieldset__heading">
        Please confirm report details 
        </h1>
      </legend>

{{ govukSummaryList({
  attributes: {
    "id": "report-summary"
  },
  
  rows: [
    {
      key: {
        text: "Subject ID"
      },
      value: {
        text: subjectId
      },
      actions: {
        items: [
          {
            attributes: {
              "id": "change-subject-id"
              },
            href: "/subject-id",
            text: "Change",
            visuallyHiddenText: "subject ID"
          }
        ]
      }
    },
    {
      key: {
        text: "Case ID"
      },
      value: {
        text: caseReference
      },
      actions: {
        items: [
          {
              attributes: {
            "id": "change-case-id"
            },
            href: "/inputs",
            text: "Change",
            visuallyHiddenText: "case ID"
          }
        ]
      }
    },
    {
      key: {
        text: "Query date range"
      },
      value: {
        text: dateRange
      },
      actions: {
        items: [
          {
            attributes: {
            "id": "change-date-range"
            },
            href: "/inputs",
            text: "Change",
            visuallyHiddenText: "date range"
          }
        ]
      }
    },
    {
      key: {
        text: "Products selected"
      },
      value: {
        html: selectedList | replace (",", "<br>")
      },
      actions: {
        items: [
          {
            attributes: {
            "id": "change-products"
            },
            href: "/product-selection",
            text: "Change",
            visuallyHiddenText: "products"
          }
        ]
      }
    }
  ]
}) }}
<p>By accepting these details you are confirming that, to the best of your knowledge, these details are correct.</p>

  {{ govukButton({
    text: "Accept and create report",
    id: "accept-confirm",
    preventDoubleClick: true
  }) }}
  </form>

  {% endblock %}