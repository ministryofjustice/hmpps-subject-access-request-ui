{% extends "../partials/layout.njk" %}
{% set mainClasses = "app-container govuk-body" %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "../components/multiselect.njk" import multiSelect %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{%- from "moj/components/alert/macro.njk" import mojAlert -%}

{% block content %}

{% if selectedProductsError %}
  {% set selectedProductsErrorMessage = { text: selectedProductsError } %}
  {% set showErrors = true %}
{% endif %}

{% if showErrors %}
  {{ govukErrorSummary({
    titleText: "There is a problem!",
    errorList: [
      {
        text: selectedProductsError
      }
    ]
  }) }}
{% endif %}

{% if suspendedProductsList %}
    {% set suspendedProductsBulletList %}
    <ul class="govuk-list govuk-list--bullet" id="suspended-services-alert-list">
      {% for item in suspendedProductsList %}
        <li>{{ item.label }}</li>
      {% endfor %}
    </ul>
    {% endset %}

    {% if suspendedProductsList | length > 1 %}
        {% set suspendedWarningTitle = 'Products Suspended' %}
        {% set suspendedWarningDesc = '<p>The following products are currently Suspended</p>' ~ suspendedProductsBulletList ~ '<p>You can continue to submit your request however the report will <b>NOT</b> complete until all selected products are Active</p>' %}
    {% else %}
        {% set suspendedWarningTitle = 'Product Suspended' %}
        {% set suspendedWarningDesc = '<p>The following products are currently Suspended</p>' ~ suspendedProductsBulletList ~ '<p>You can continue submit your request however the report will <b>NOT</b> complete until the suspended product is Active</p>' %}
    {% endif %}

    {{ mojAlert({
        variant: "warning",
        title: suspendedWarningTitle,
        showTitleAsHeading: true,
        dismissible: false,
        html: suspendedWarningDesc
    }) }}
{% endif %}

{{ govukBackLink({
  text: "Back",
  href: "/inputs"
}) }}

<form action="/product-selection" method="post">
  <input type="hidden" name="_csrf" value="{{ csrfToken }}">

  <div class="govuk-form-group">
    <legend class="govuk-fieldset__legend govuk-fieldset__legend--l">
        <h1 class="govuk-fieldset__heading">
        Select Products
        </h1>
      </legend>
      <div id="waste-hint" class="govuk-hint">
        Select products to collect data from.
      </div>

      {{ multiSelect({
          headers: ["Product Name", "Product Status"],
          itemGroupName: "selectedProducts",
          categorisedItems: categorisedProducts,
          selectedItems: selectedList,
          errorMessage: selectedProductsErrorMessage
      }) }}
  </div>

  {{ govukButton({
      text: buttonText,
      id: "input-submit",
      type: "submit",
      preventDoubleClick: true
  }) }}

</form>
{% endblock %}